# Gabarit de configuration : copier ce fichier en `.env` puis remplir les
# valeurs réelles. `.env` n'est jamais versionné (voir .gitignore) ; c'est
# la seule source de vérité pour tout ce qui varie selon l'environnement
# (dev local, Docker, prod...). Ne JAMAIS mettre de valeur en dur dans le
# code Python : tout passe par ici (voir config/settings.py).

# Clé secrète Django, utilisée pour la signature des sessions/cookies/tokens.
# Générer une valeur unique par environnement, par exemple avec :
#   uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-moi

# True en dev uniquement. Doit impérativement être False en prod (affiche
# sinon des informations sensibles en cas d'erreur).
DJANGO_DEBUG=True

# Liste de noms d'hôtes autorisés à servir l'application, séparés par des
# virgules. Ignoré si DJANGO_DEBUG=True mais obligatoire en prod.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Connexion PostgreSQL au format standard 12-factor :
#   postgres://UTILISATEUR:MOT_DE_PASSE@HOTE:PORT/NOM_BASE
# En local avec Laragon, l'authentification est en mode "trust" pour
# localhost : le mot de passe peut être omis (postgres://postgres@...).
# Dans un futur Docker/prod, HOTE devient le nom du service (ex: "db") et
# un mot de passe doit être renseigné.
DATABASE_URL=postgres://postgres@localhost:5432/yproject
